{
  "name": "kaplay-layout",
  "version": "1.0.1",
  "description": "a wrapper around Yoga that provides real CSS flexbox in kaplay.",
  "license": "MIT",
  "author": "numblr",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "keywords": [
    "kaplay",
    "kaplayjs",
    "layout",
    "flexbox"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hinum/kaplay-layout.git"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier . --write",
    "lint": "prettier . --check",
    "test": "vitest",
    "docs": "typedoc --options ./typedoc.json",
    "docs:preview": "vite dev ./docs/ --open",
    "prepare": "husky"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/yoga-layout": "^1.9.7",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/browser-preview": "^4.1.8",
    "express": "^5.2.1",
    "husky": "^9.1.7",
    "prettier": "3.8.3",
    "typedoc": "^0.28.19",
    "vite": "^8.0.14",
    "vite-express": "^0.22.1",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "kaplay": "x.x.x-0"
  },
  "dependencies": {
    "yoga-layout": "^3.2.1"
  }
}
